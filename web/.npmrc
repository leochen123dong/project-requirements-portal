# Vite-recommended npm config.
# `node-linker=hoisted` flattens node_modules (instead of nested), which
# avoids rollup's nested platform-specific optional binaries writing
# empty "version" entries to package-lock.json on amd64 runners.
# See https://vitejs.dev/guide/troubleshooting.html
node-linker=hoisted
optional=false
audit=false
fund=false